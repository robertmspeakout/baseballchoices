generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String   @id @default(cuid())
  firstName        String
  lastName         String
  email            String   @unique
  passwordHash     String
  role             String   @default("USER")
  emailVerified    Boolean  @default(false)
  trialExpiresAt   DateTime
  membershipActive     Boolean  @default(false)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  subscriptionStatus   String?  // "active" | "trialing" | "past_due" | "canceled" | "unpaid"
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  profile       Profile?
  preferences   Preferences?
  schoolData    UserSchoolData[]
  notifications Notification[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, code])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Profile {
  id                String  @id @default(cuid())
  userId            String  @unique
  gradYear          Int?
  primaryPosition   String?
  secondaryPosition String?
  city              String?
  state             String?
  zipCode           String?
  highSchool        String?
  travelBall        String?
  gpa               String?
  gpaType           String?
  satScore          String?
  actScore          String?
  profilePic        String?
  backgroundPic     String?
  profileComplete   Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Preferences {
  id                   String  @id @default(cuid())
  userId               String  @unique
  divisionPreference   String?
  preferredDivisions   String?
  maxDistanceFromHome  Int?
  preferredRegions     String?
  maxTuition           Int?
  schoolSize           String?
  highAcademic         Boolean @default(false)
  competitiveness      String?
  draftImportance      String?
  preferredConferences String?
  preferredTiers       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSchoolData {
  id               String   @id @default(cuid())
  userId           String
  schoolId         Int
  priority         Int      @default(0)
  notes            String   @default("")
  lastContacted    String?
  recruitingStatus String?
  theyveSeenMe     String?
  detail           String?
  myContactName    String?
  myContactEmail   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  schoolId  Int
  type      String   // "game_result" | "game_today" | "coach_change" | "championship" | "conference_change" | "ranking_change"
  title     String
  body      String
  link      String?
  schoolLogo String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}
